{
  "database": "oncoquery",
  "collections": {
    "users": {
      "description": "Registered users of the platform",
      "fields": {
        "_id":             { "type": "ObjectId",          "note": "Auto-generated document identifier" },
        "email":           { "type": "string",            "required": true, "unique": true },
        "name":            { "type": "string",            "required": false },
        "hashed_password": { "type": "string",            "required": true },
        "role":            { "type": "enum",              "values": ["user", "admin"], "default": "user" },
        "created_at":      { "type": "datetime",          "default": "now" }
      },
      "indexes": [
        { "field": "email", "unique": true }
      ]
    },

    "projects": {
      "description": "Optional folders to organise chat sessions",
      "fields": {
        "_id":         { "type": "ObjectId", "note": "Auto-generated document identifier" },
        "user_id":     { "type": "string",   "required": true,  "ref": "users._id" },
        "name":        { "type": "string",   "required": true },
        "description": { "type": "string",   "required": false },
        "created_at":  { "type": "datetime", "default": "now" },
        "updated_at":  { "type": "datetime", "default": "now" }
      },
      "indexes": [
        { "field": "user_id" }
      ]
    },

    "chat_sessions": {
      "description": "Conversation sessions between user and AI agent",
      "fields": {
        "_id":              { "type": "ObjectId", "note": "Auto-generated document identifier" },
        "user_id":          { "type": "string",   "required": true,  "ref": "users._id" },
        "project_id":       { "type": "string",   "required": false, "ref": "projects._id", "note": "null if not assigned to a project" },
        "title":            { "type": "string",   "required": false, "note": "Auto-generated from first message" },
        "mcp_sources_used": { "type": "array",    "items": "string", "note": "e.g. UniProt, PDB, AlphaFold" },
        "created_at":       { "type": "datetime", "default": "now" },
        "updated_at":       { "type": "datetime", "default": "now" },
        "messages": {
          "type": "array",
          "note": "Embedded subdocument array — not a separate collection",
          "items": {
            "role":             { "type": "enum",     "values": ["user", "assistant"] },
            "content":          { "type": "string" },
            "sources_queried":  { "type": "array",    "items": "string" },
            "timestamp":        { "type": "datetime", "default": "now" }
          }
        }
      },
      "indexes": [
        { "field": "user_id" },
        { "field": "project_id" },
        { "field": "updated_at", "order": "descending" }
      ]
    },

    "export_logs": {
      "description": "Record of all exports generated by users",
      "fields": {
        "_id":        { "type": "ObjectId", "note": "Auto-generated document identifier" },
        "user_id":    { "type": "string",   "required": true, "ref": "users._id" },
        "session_id": { "type": "string",   "required": true, "ref": "chat_sessions._id" },
        "format":     { "type": "enum",     "values": ["pdf", "csv"] },
        "created_at": { "type": "datetime", "default": "now" }
      },
      "indexes": [
        { "field": "user_id" },
        { "field": "session_id" }
      ]
    }
  },

  "references": [
    { "from": "projects.user_id",       "to": "users._id",            "cardinality": "N:1" },
    { "from": "chat_sessions.user_id",  "to": "users._id",            "cardinality": "N:1" },
    { "from": "chat_sessions.project_id","to": "projects._id",        "cardinality": "N:1", "optional": true },
    { "from": "export_logs.user_id",    "to": "users._id",            "cardinality": "N:1" },
    { "from": "export_logs.session_id", "to": "chat_sessions._id",    "cardinality": "N:1" }
  ]
}